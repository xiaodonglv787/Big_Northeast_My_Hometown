class SnowFlake:

    def __init__(self, canvas):

        self.canvas = canvas

        self.x = random.randint(0, WINDOW_W)

        self.y = random.randint(-10, WINDOW_H + 10)

        self.size = random.randint(2, 5)

        self.speed = random.uniform(0.5, 2.0)

        self.wind = random.uniform(-0.3, 0.3)

        self.id = None



    def update(self):

        if self.id:

            self.canvas.delete(self.id)

        self.y += self.speed

        self.x += self.wind

        if self.y > WINDOW_H + 10:

            self.y = -10

            self.x = random.randint(0, WINDOW_W)

        self.id = self.canvas.create_oval(

            self.x - self.size, self.y - self.size,

            self.x + self.size, self.y + self.size,

            fill="white", outline="lightblue", width=1

        )





class DongBeiWindow:

    def __init__(self, x, y):

        self.win = tk.Toplevel(root)

        self.win.title("大东北我的家乡 DJ何鹏版")

        # 不使用 overrideredirect，保留标准标题栏和 X 按钮

        self.win.geometry(f"{WINDOW_W}x{WINDOW_H}+{x}+{y}")

        self.win.attributes('-topmost', True)



        self.bg = random.choice(COLORS)

        self.win.configure(bg=self.bg)



        self.canvas = tk.Canvas(

            self.win, width=WINDOW_W, height=WINDOW_H,

            bg=self.bg, highlightthickness=0, bd=0

        )

        self.canvas.pack(fill=tk.BOTH, expand=True)



        self.text_id = self.canvas.create_text(

            WINDOW_W // 2, WINDOW_H // 2,

            text=random.choice(LYRICS),

            font=("Microsoft YaHei", 9, "bold"),

            fill="#2c5f8a",

            anchor="center"

        )



        self.snows = [SnowFlake(self.canvas) for _ in range(3)]



        self.x = float(x)

        self.y = float(y)

        self.vx = random.uniform(-2, 2)

        self.vy = random.uniform(-2, 2)

        self.angle = random.uniform(0, math.pi * 2)

        self.amplitude = random.uniform(20, 60)

        self.frequency = random.uniform(0.02, 0.05)



        # 绑定关闭事件

        self.win.protocol("WM_DELETE_WINDOW", self.on_window_close)



    def on_window_close(self):

        """单个窗口关闭时检查是否全部关闭"""

        self.destroy()

        if self in windows:

            windows.remove(self)



    def update(self, now):

        global stage, SCREEN_W, SCREEN_H

        try:

            elapsed = now - stage_start



            if stage == 0:

                self.x += self.vx * 2

                self.y += self.vy * 2

                if self.x <= 0 or self.x >= SCREEN_W - WINDOW_W:

                    self.vx *= -1

                if self.y <= 0 or self.y >= SCREEN_H - WINDOW_H:

                    self.vy *= -1



            elif stage == 1:

                self.angle += 0.05

                self.x += math.cos(self.angle) * 3

                self.y += math.sin(self.angle * 1.3) * 3

                self.x = max(0, min(self.x, SCREEN_W - WINDOW_W))

                self.y = max(0, min(self.y, SCREEN_H - WINDOW_H))



            elif stage == 2:

                self.x += math.sin(self.angle + elapsed * 0.01) * 1.5

                self.y += math.cos(self.angle * 0.7 + elapsed * 0.01) * 1.5



            elif stage == 3:

                self.vx += random.uniform(-0.5, 0.5)

                self.vy += random.uniform(-0.5, 0.5)

                self.vx = max(-6, min(6, self.vx))

                self.vy = max(-6, min(6, self.vy))

                self.x += self.vx

                self.y += self.vy

                if self.x <= 0 or self.x >= SCREEN_W - WINDOW_W:

                    self.vx *= -1

                if self.y <= 0 or self.y >= SCREEN_H - WINDOW_H:

                    self.vy *= -1



            self.x = max(0, min(self.x, SCREEN_W - WINDOW_W))

            self.y = max(0, min(self.y, SCREEN_H - WINDOW_H))



            self.win.geometry(f"{WINDOW_W}x{WINDOW_H}+{int(self.x)}+{int(self.y)}")



            for s in self.snows:

                s.update()



            if random.random() < 0.02:

                self.canvas.itemconfig(self.text_id, text=random.choice(LYRICS))

        except tk.TclError:

            pass



    def destroy(self):

        try:

            self.win.destroy()

        except:

            pass





def stage_manager():

    global stage, stage_start, running

    while running:

        now = time.time()

        elapsed = now - stage_start

        if stage == 0 and elapsed > 5:

            stage = 1; stage_start = now

        elif stage == 1 and elapsed > 7:

            stage = 2; stage_start = now

        elif stage == 2 and elapsed > 7:

            stage = 3; stage_start = now

        time.sleep(0.5)





def animation_loop():

    global running, windows

    while running:

        now = time.time()

        for w in windows[:]:

            try:

                w.update(now)

            except:

                if w in windows:

                    windows.remove(w)

        time.sleep(0.03)





def spawn_windows():

    global running, MAX_WINDOWS, SCREEN_W, SCREEN_H

    count = 0

    while running and count < MAX_WINDOWS:

        if len(windows) < MAX_WINDOWS:

            x = random.randint(0, SCREEN_W - WINDOW_W)

            y = random.randint(0, SCREEN_H - WINDOW_H)

            try:

                w = DongBeiWindow(x, y)

                windows.append(w)

                count += 1

            except:

                pass

        time.sleep(0.06)



    while running:

        dead = [w for w in windows if not w.win.winfo_exists()]

        for w in dead:

            if w in windows:

                windows.remove(w)

        if len(windows) < MAX_WINDOWS - 5:

            try:

                x = random.randint(0, SCREEN_W - WINDOW_W)

                y = random.randint(0, SCREEN_H - WINDOW_H)

                w = DongBeiWindow(x, y)

                windows.append(w)

            except:

                pass

        time.sleep(1)





