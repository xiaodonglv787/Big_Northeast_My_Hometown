def play_music():

    """后台播放音乐 (DJ何鹏版) - 使用 pygame 内嵌播放，不弹出外部窗口"""

    global music_initialized

    if not os.path.exists(MUSIC_FILE):

        print(f"[警告] 音乐文件未找到: {MUSIC_FILE}")

        return



    try:

        import pygame

        pygame.mixer.init()

        pygame.mixer.music.load(MUSIC_FILE)

        pygame.mixer.music.set_volume(0.7)

        pygame.mixer.music.play()

        music_initialized = True

        print(f"[DJ何鹏版] 正在播放(内嵌): 大东北我的家乡")

    except Exception as e:

        print(f"[错误] 播放音乐失败: {e}")





def song_timer():

    """音乐播放完毕后自动退出"""

    global running

    print(f"[DJ何鹏版] 约 {SONG_DURATION} 秒后自动退出...")



    # 等待音乐播完（每0.5秒检查一次）

    for _ in range(SONG_DURATION * 2):

        if not running:

            return

        time.sleep(0.5)



    if running:

        print("[DJ何鹏版] 音乐播放完毕，正在退出...")

        root.after(100, on_close)





def on_close():

    global running, music_initialized

    running = False



    # 停止音乐播放

    if music_initialized:

        try:

            import pygame

            pygame.mixer.music.stop()

            pygame.mixer.quit()

        except:

            pass



    for w in windows:

        w.destroy()

    windows.clear()

    try:

        root.destroy()

    except:

        pass

    sys.exit(0)





